# Variable is number or text


# Variable using equal (=) is called the 'assignment operator'
name = "Petrus"
age = 24
height = 172


# Show the output
print(name)


# Rules of variable names
# Character: Start from alphabeth (a-z) or underline (_). Dont start with number
# Case-Sensitive: Variable 'Name' and 'name' is different
# Space: There cant be no space, using underscore (_) as a replacement
# Forbidden Key: You cant use word but Python have special function, like if, else, print, while, etc



